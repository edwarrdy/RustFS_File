# App Environment (development/production)
NODE_ENV=development
PORT=3300

# Database Configuration
# DATABASE_PATH=./data/file-server.db

# RustFS / S3 Configuration
# Internal endpoint (used by the server)
RUSTFS_ENDPOINT=http://localhost:19000
# External endpoint (used for pre-signed URLs, browser-accessible)
RUSTFS_PUBLIC_ENDPOINT=http://localhost:19000
RUSTFS_REGION=us-east-1
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET_NAME=bucket
