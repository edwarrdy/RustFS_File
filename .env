# ==============================================================================
# 应用环境配置 (development / production)
# ==============================================================================
NODE_ENV=development
PORT=3300

# ==============================================================================
# 数据库配置
# ==============================================================================
# 开发环境通常使用相对路径，生产环境(Docker)建议使用 /app/data/file-server.db
DATABASE_PATH="./data/file-server.db"

# ==============================================================================
# RustFS / S3 存储配置
# ==============================================================================

# 1. API服务器内部访问地址 (Internal Endpoint)
# 开发环境: 通常是 http://localhost:19000
# 生产环境: 必须改为 http://rustfs-storage:9000 (容器名)
RUSTFS_ENDPOINT="http://localhost:19000"

# 2. 浏览器/前端访问地址 (Public Endpoint)
# 开发环境: 通常是 http://localhost:19000
# 生产环境: 必须改为 http://你的服务器公网IP:9000
RUSTFS_PUBLIC_ENDPOINT="http://localhost:19000"

# 3. 存储凭据与参数
RUSTFS_REGION="us-east-1"
RUSTFS_ACCESS_KEY="rustfsadmin"
RUSTFS_SECRET_KEY="rustfsadmin"
RUSTFS_BUCKET_NAME="bucket"
